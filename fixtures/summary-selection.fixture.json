{
  "name": "summary selection quick actions",
  "maxChars": 200,
  "textCases": [
    {
      "name": "short chinese selection is useful",
      "text": "这是一个有效选区",
      "expectedUseful": true
    },
    {
      "name": "single chinese character is useful",
      "text": "佬",
      "expectedUseful": true
    },
    {
      "name": "short latin acronym is useful",
      "text": "AI",
      "expectedUseful": true
    },
    {
      "name": "short infra acronym is useful",
      "text": "CF",
      "expectedUseful": true
    },
    {
      "name": "short floor reference is useful",
      "text": "7楼",
      "expectedUseful": true
    },
    {
      "name": "short punctuation is ignored",
      "text": "，。",
      "expectedUseful": false
    },
    {
      "name": "symbol only selection is ignored",
      "text": "→ / #",
      "expectedUseful": false
    },
    {
      "name": "emoji only selection is ignored",
      "text": "😀",
      "expectedUseful": false
    },
    {
      "name": "whitespace is normalized",
      "text": "第一段\n\n    第二段\t第三段",
      "expectedText": "第一段 第二段 第三段",
      "expectedUseful": true
    },
    {
      "name": "long selection is truncated",
      "text": "abcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyz",
      "expectedUseful": true,
      "expectedTruncated": true
    }
  ],
  "promptCases": [
    {
      "name": "explain sends immediately",
      "action": "explain",
      "text": "这段涉及楼层争议和主要结论",
      "expectedAutoSend": true,
      "expectedContains": ["请解释下面这段总结内容", "原帖讨论", "不要编造", "这段涉及楼层争议和主要结论"]
    },
    {
      "name": "simplify sends immediately",
      "action": "simplify",
      "text": "这段内容需要进一步精简",
      "expectedAction": "simplify",
      "expectedAutoSend": true,
      "expectedContains": ["进行精简", "更短、更清晰", "这段内容需要进一步精简"]
    },
    {
      "name": "quote fills draft",
      "action": "quote",
      "text": "只引用不自动发送",
      "expectedAction": "quote",
      "expectedAutoSend": false,
      "expectedContains": ["> 只引用不自动发送"],
      "expectedPrompt": "> 只引用不自动发送\n\n"
    },
    {
      "name": "quote preserves non-empty lines",
      "action": "quote",
      "text": "第一行\n\n  第二行  ",
      "expectedAction": "quote",
      "expectedAutoSend": false,
      "expectedContains": ["> 第一行", "> 第二行"],
      "expectedPrompt": "> 第一行\n> 第二行\n\n"
    },
    {
      "name": "unknown action falls back to quote",
      "action": "unknown",
      "text": "未知动作应走引用",
      "expectedAction": "quote",
      "expectedAutoSend": false,
      "expectedContains": ["> 未知动作应走引用"]
    }
  ],
  "distShape": {
    "requiredContains": [
      "getSummarySelectionMenuHtml",
      "bindSummarySelectionMenu",
      "getSummarySelectionState",
      "handleSummarySelectionAction",
      "fillChatInputWithSelectionPrompt",
      "summarySelectionOpenTimerId",
      "summarySelectionRequestSeq",
      "clearCurrentSelection",
      "data-summary-selection-action=\"explain\"",
      "data-summary-selection-action=\"simplify\"",
      "data-summary-selection-action=\"quote\"",
      "summary-selection-menu",
      "meaningful.length > 0",
      "const hasDraft = !!input?.value.trim()",
      "this.clearManagedTimeout(this.summarySelectionOpenTimerId)",
      "this.clearCurrentSelection();",
      "UIRegistry.get('style1').bindSummarySelectionMenu",
      "clearCurrentSelection: UIRegistry.get('style1').clearCurrentSelection"
    ],
    "requiredRegex": [
      "shadow\\?\\.getSelection\\?\\.\\(\\) \\|\\| window\\.getSelection\\?\\.\\(\\)",
      "requestSeq !== this\\.summarySelectionRequestSeq",
      "this\\.switchTab\\('chat'\\)",
      "if \\(isStreaming\\) this\\.closeSummarySelectionMenu\\?\\.\\(\\)",
      "Core\\.buildSummarySelectionPrompt\\(action, selection\\.text\\)"
    ]
  }
}
